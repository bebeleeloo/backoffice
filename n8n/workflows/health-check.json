{
  "id": "health-check-001",
  "name": "Broker Health Check",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "*/5 * * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Every 5 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "url": "http://api:8080/health/ready",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "check-api",
      "name": "Check API Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "api-status-code",
              "name": "apiStatusCode",
              "value": "={{ $json.statusCode }}",
              "type": "number"
            },
            {
              "id": "api-body",
              "name": "apiBody",
              "value": "={{ $json.body }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "save-api-result",
      "name": "Save API Result",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [440, 0]
    },
    {
      "parameters": {
        "url": "http://auth:8082/health/ready",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "check-auth",
      "name": "Check Auth Health",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [660, 0],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "api-ok",
              "leftValue": "={{ $('Save API Result').first().json.apiStatusCode }}",
              "rightValue": 200,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            },
            {
              "id": "auth-ok",
              "leftValue": "={{ $json.statusCode }}",
              "rightValue": 200,
              "operator": {
                "type": "number",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "check-status",
      "name": "Both Healthy?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "result",
              "name": "result",
              "value": "All services healthy",
              "type": "string"
            },
            {
              "id": "api-body",
              "name": "apiResponse",
              "value": "={{ $('Save API Result').first().json.apiBody }}",
              "type": "string"
            },
            {
              "id": "auth-body",
              "name": "authResponse",
              "value": "={{ $('Check Auth Health').first().json.body }}",
              "type": "string"
            },
            {
              "id": "timestamp",
              "name": "checkedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "all-healthy",
      "name": "All Healthy",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1100, -80]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "result",
              "name": "result",
              "value": "Health check FAILED",
              "type": "string"
            },
            {
              "id": "api-status",
              "name": "apiStatusCode",
              "value": "={{ $('Save API Result').first().json.apiStatusCode ?? 0 }}",
              "type": "number"
            },
            {
              "id": "auth-status",
              "name": "authStatusCode",
              "value": "={{ $('Check Auth Health').first().json.statusCode ?? 0 }}",
              "type": "number"
            },
            {
              "id": "timestamp",
              "name": "checkedAt",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "failure-details",
      "name": "Capture Failure",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1100, 80]
    }
  ],
  "connections": {
    "Every 5 Minutes": {
      "main": [
        [
          { "node": "Check API Health", "type": "main", "index": 0 }
        ]
      ]
    },
    "Check API Health": {
      "main": [
        [
          { "node": "Save API Result", "type": "main", "index": 0 }
        ]
      ]
    },
    "Save API Result": {
      "main": [
        [
          { "node": "Check Auth Health", "type": "main", "index": 0 }
        ]
      ]
    },
    "Check Auth Health": {
      "main": [
        [
          { "node": "Both Healthy?", "type": "main", "index": 0 }
        ]
      ]
    },
    "Both Healthy?": {
      "main": [
        [
          { "node": "All Healthy", "type": "main", "index": 0 }
        ],
        [
          { "node": "Capture Failure", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    { "name": "monitoring" }
  ]
}
