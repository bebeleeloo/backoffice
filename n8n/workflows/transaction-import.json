      "id": "lookup-currency",
      "name": "Lookup Currency",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2750,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $('Loop Items').first().json;\nconst currencies = $input.first().json.body || [];\nconst curr = currencies.find(c => c.code === row.currencyCode);\nconst today = new Date().toISOString().split('T')[0];\nconst payload = curr ? {\n  transactionDate: today,\n  amount: parseFloat(row.amount),\n  currencyId: curr.id,\n  referenceNumber: row.referenceNumber || null,\n  description: row.description || null,\n  comment: row.comment || null,\n  externalId: row.externalId\n} : null;\nreturn [{ json: { found: !!curr, payload } }];\n"
      },
      "id": "build-non-trade",
      "name": "Build Non-Trade",
      "type": "n8n-nodes-base.code",
