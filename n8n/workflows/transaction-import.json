          { "node": "Evaluate", "type": "main", "index": 0 }
        ]
      ]
    },
    "Evaluate": {
      "main": [
        [
          { "node": "Should Create?", "type": "main", "index": 0 }
        ]
      ]
    },
    "Should Create?": {
      "main": [
        [
          { "node": "Lookup Account", "type": "main", "index": 0 }
        ],
