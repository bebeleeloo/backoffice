      "id": "is-trade",
      "name": "Is Trade?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2500,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://gateway:8090/api/v1/instruments?q={{ encodeURIComponent($('Loop Items').first().json.instrumentSymbol) }}&pageSize=10",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Login').first().json.accessToken }}"
            }
          ]
        },
        "options": {}
      },
      "id": "lookup-instrument",
      "name": "Lookup Instrument",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2750,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const row = $('Loop Items').first().json;\nconst items = $input.first().json.items || [];\nconst inst = items.find(i => i.symbol === row.instrumentSymbol);\nconst today = new Date().toISOString().split('T')[0];\nconst payload = inst ? {\n  instrumentId: inst.id,\n  transactionDate: today,\n  side: row.side,\n  quantity: parseFloat(row.quantity),\n  price: parseFloat(row.price),\n  commission: row.commission ? parseFloat(row.commission) : null,\n  venue: row.venue || null,\n  comment: row.comment || null,\n  externalId: row.externalId\n} : null;\nreturn [{ json: { found: !!inst, payload } }];\n"
      },
      "id": "build-trade",
      "name": "Build Trade",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3000,
        100
