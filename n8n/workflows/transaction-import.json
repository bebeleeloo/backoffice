      "id": "create-non-trade",
      "name": "Create Non-Trade",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3500,
        500
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const row = $('Loop Items').first().json;\nconst response = $input.first().json;\nconst statusCode = response.statusCode || 0;\nlet log;\nif (statusCode === 201) {\n  log = row.externalId + ': created';\n} else {\n  const msg = response.body?.detail || response.body?.title || response.error?.message || ('HTTP ' + statusCode);\n  log = row.externalId + ': failed (' + msg + ')';\n}\nreturn [{ json: { done: true, log, created: statusCode === 201 } }];\n"
      },
      "id": "record-result",
      "name": "Record Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3750,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const totalRows = $('Parse CSV').all().length;\nlet results = [];\ntry {\n  results = $('Record Result').all();\n} catch (e) {\n  // Record Result never executed \u2014 all items were skipped\n}\nconst imported = results.filter(r => r.json.created).length;\nconst details = results.map(r => r.json.log);\nconst skipped = totalRows - results.length;\n\nlet message;\nif (imported > 0) {\n  message = 'Transaction import complete';\n} else if (skipped > 0) {\n  message = 'All transactions already imported';\n} else {\n  message = 'No valid transactions found';\n}\nreturn [{ json: { imported, skipped, message, details } }];"
      },
      "id": "build-summary",
      "name": "Build Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        700
      ]
    }
