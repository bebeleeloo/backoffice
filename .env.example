# Copy to .env and adjust values for your environment.
# .env is gitignored — never commit real secrets.

PG_PASSWORD=Your_Strong_Password123
JWT_SECRET=this-is-a-development-secret-key-min-32-chars!!
ADMIN_PASSWORD=Admin123!
DEFAULT_DEMO_PASSWORD=Admin123!
SEED_DEMO_DATA=true

# CORS origin for auth, api, gateway services (default: http://localhost:3000)
# CORS_ORIGIN=https://your-domain.com

# ASP.NET environment (default: Production)
# ASPNETCORE_ENVIRONMENT=Production

# n8n Workflow Orchestrator
N8N_DB_PASSWORD=n8n_password
N8N_PASSWORD=Admin123!
# N8N_WEBHOOK_URL=https://your-domain.com:5678/

# n8n secure cookie (set to true in production with HTTPS)
# N8N_SECURE_COOKIE=true

# n8n credential "Broker API Auth" (httpBasicAuth) must be created
# in n8n UI or via import script with the admin username/password
