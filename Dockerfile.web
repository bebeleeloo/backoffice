FROM node:20-alpine3.21 AS build
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

COPY frontend/pnpm-workspace.yaml frontend/pnpm-lock.yaml frontend/package.json frontend/turbo.json ./
COPY frontend/apps/backoffice/package.json apps/backoffice/package.json
COPY frontend/apps/auth/package.json apps/auth/package.json
COPY frontend/apps/config/package.json apps/config/package.json
COPY frontend/packages/ui-kit/package.json packages/ui-kit/package.json
COPY frontend/packages/auth-module/package.json packages/auth-module/package.json
RUN pnpm install --frozen-lockfile

COPY frontend/tsconfig.base.json ./
COPY frontend/packages/ packages/
COPY frontend/apps/backoffice/ apps/backoffice/
COPY frontend/apps/auth/ apps/auth/
COPY frontend/apps/config/ apps/config/
RUN pnpm exec turbo build

FROM nginx:1.27-alpine AS runtime
RUN sed -i 's/listen\s*80;/listen 8080;/' /etc/nginx/conf.d/default.conf && \
    sed -i '/^pid/c\pid /tmp/nginx.pid;' /etc/nginx/nginx.conf && \
    chown -R nginx:nginx /var/cache/nginx /var/log/nginx /etc/nginx/conf.d /run
COPY --from=build --chown=nginx:nginx /app/apps/backoffice/dist /usr/share/nginx/html/backoffice
COPY --from=build --chown=nginx:nginx /app/apps/auth/dist /usr/share/nginx/html/auth
COPY --from=build --chown=nginx:nginx /app/apps/config/dist /usr/share/nginx/html/config
COPY --chown=nginx:nginx frontend/apps/backoffice/public/logo.svg /usr/share/nginx/html/logo.svg
COPY --chown=nginx:nginx frontend/nginx.conf /etc/nginx/conf.d/default.conf
COPY --chown=nginx:nginx frontend/security-headers.conf /etc/nginx/security-headers.conf
USER nginx
EXPOSE 8080
